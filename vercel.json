{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/services/web-design", "destination": "/services-web.html" },
    { "source": "/services/digital-marketing", "destination": "/services-marketing.html" },
    { "source": "/about", "destination": "/about.html" },
    { "source": "/blog", "destination": "/blog.html" },
    { "source": "/work/:slug", "destination": "/work.html" }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.webature.co.uk" }],
      "destination": "https://webature.co.uk/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
